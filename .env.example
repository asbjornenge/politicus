# Copy to .env and fill in. .env is gitignored.

# --- Wallet (used by ./scripts/*) ---
POLITICUS_PRIVATE_KEY=edsk...
POLITICUS_PUBLIC_KEY=edpk...
POLITICUS_ADDRESS=tz1...

# --- Tezos network ---
POLITICUS_RPC_URL=https://rpc.shadownet.teztnets.com
POLITICUS_FAUCET_URL=https://faucet.shadownet.teztnets.com
POLITICUS_NETWORK=shadownet
TZKT_API=https://api.shadownet.tzkt.io

# --- Postgres (docker-compose) ---
POSTGRES_USER=politicus
POSTGRES_PASSWORD=politicus
POSTGRES_DB=politicus

# --- Contract addresses (from deployments.json) ---
# For contracts split into Logic + DataStore, the _REGISTRY env points to the
# Logic contract (where users sign txs) and the _DATA_STORE env points to the
# DataStore contract (where bigmaps live; the indexer reads from here).
VARIABLES_ADDRESS=KT1...          # = VariablesLogic
VARIABLES_DATA_STORE=KT1...
TREASURY_ADDRESS=KT1...
IDENTITY_REGISTRY=KT1...
BIT_REGISTRY=KT1...               # = BitRegistryLogic
BIT_DATA_STORE=KT1...
PETITION_REGISTRY=KT1...          # = PetitionLogic
PETITION_DATA_STORE=KT1...
MODERATION_REGISTRY=KT1...
SYNDICATE_REGISTRY=KT1...
PROFILE_REGISTRY=KT1...

# --- IPFS (used by the API for content storage) ---
IPFS_UPLOAD_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080

# --- Public hostname served by Traefik (used in docker-compose labels) ---
POLITICUS_HOST=politicus.localhost
